# PostgreSQL connection (SQLAlchemy URL)
DATABASE_URL=postgresql+psycopg://vzla:vzla@localhost:5432/venezuelasolidaria

# Comma-separated list of allowed CORS origins (the Next.js frontend)
CORS_ORIGINS=http://localhost:3000

# Public site URL — used to build absolute share links (`link`) in the
# federation API feed (/api/v1). Set to the real domain in production.
PUBLIC_SITE_URL=https://www.venezuelasolidaria.com

# Port the Flask API listens on
PORT=5001

# Secret used to sign admin JWTs — use a long random value in production
SECRET_KEY=dev-insecure-change-me
# How long an admin session token stays valid (hours)
JWT_EXP_HOURS=12

# Initial moderator account, created on first startup if no admin exists
ADMIN_EMAIL=admin@ejemplo.org
ADMIN_PASSWORD=cambia-esta-clave

# ---- Anti-abuse / DoS ----
# Default per-IP rate limit applied to every endpoint
RATELIMIT_DEFAULT=240 per hour
# Rate-limit storage. Use redis://host:6379 in production (multi-process safe)
RATELIMIT_STORAGE_URI=memory://
# Max request body size in bytes (default 64 KB)
MAX_CONTENT_LENGTH=65536
# Number of trusted reverse-proxy hops (set to 1+ behind nginx/Render/etc. so
# rate limits key on the real client IP). 0 = no proxy.
PROXY_HOPS=0

# ---- Tiempo real (SSE) ----
# Segundos entre latidos que mantienen viva la conexión del stream
SSE_HEARTBEAT_SECONDS=20

# ---- Cloudinary (subida firmada; el SECRET vive SOLO aquí, nunca en el frontend) ----
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret
# Carpeta donde se guardan las imágenes (se firma en el servidor)
CLOUDINARY_FOLDER=VenezuelaSolidaria
