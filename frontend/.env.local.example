# Base URL of the Flask API
NEXT_PUBLIC_API_BASE=http://localhost:5001

# Cloudinary (subida de imágenes con unsigned upload preset; valores públicos)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=tu-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=tu-unsigned-preset
# Carpeta donde se guardan las imágenes (opcional; también puedes fijarla en el preset)
NEXT_PUBLIC_CLOUDINARY_FOLDER=VenezuelaSolidaria
