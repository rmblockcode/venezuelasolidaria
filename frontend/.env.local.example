# Base URL of the Flask API
NEXT_PUBLIC_API_BASE=http://localhost:5001

# URL pública del sitio (para metadata Open Graph de los enlaces compartidos).
# Opcional en local; en producción ponlo al dominio real.
NEXT_PUBLIC_SITE_URL=https://www.venezuelasolidaria.com

# Cloudinary se configura en el BACKEND (subida firmada). El frontend no necesita
# credenciales de Cloudinary: pide la firma a /api/cloudinary/signature.
